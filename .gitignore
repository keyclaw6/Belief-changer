# Code intelligence graph cache (codebase-memory-mcp) — never commit.
.codebase-memory-mcp/
*.cbm-graph/
.codex/

# RF-02/H-F01 generated local state; canonical inputs remain tracked elsewhere.
loop/accepted/
loop/experiments/

# OS / editor cruft.
.DS_Store
*.swp
*~

# Calibration reference texts — regenerated locally from the reference EPUB (scripts/eval/extract_reference.py); extracted book text is never committed.
calibration/reference/

# Python bytecode from running the eval suite.
__pycache__/
*.pyc

# Optional local MLflow lens — git is the canonical store.
calibration/mlruns/

# Judge task files embed extracted reference text — never commit (PROGRAM §7).
loop/iterations/*/judging/tasks/
# H-F04 contains anonymous reference prose and raw calibration verdicts.
loop/iterations/*/judging/h-f04/

# dotenvx private keys stay outside Git; encrypted .env files are tracked.
.env.keys
.env.keys.*
